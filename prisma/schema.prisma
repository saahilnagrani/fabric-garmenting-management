generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  passwordHash        String
  role                UserRole       @default(USER)
  inventoryRole       InventoryRole?
  sourcingRole        SourcingRole?
  permissionOverrides String[]       @default([])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

enum InventoryRole {
  VIEWER
  EDITOR
  MANAGER
}

enum SourcingRole {
  VIEWER
  EDITOR
  MANAGER
}

// ─── CORE DOMAIN ─────────────────────────────────────────────────

model Phase {
  id                   String              @id @default(cuid())
  name                 String
  number               Int                 @unique
  startDate            DateTime?
  endDate              DateTime?
  isCurrent            Boolean             @default(false)
  isStrikedThrough     Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  products             Product[]
  fabricOrders         FabricOrder[]
  expenses             Expense[]
  accessoryPurchases   AccessoryPurchase[]
  accessoryDispatches  AccessoryDispatch[]
  fabricBalancesSource FabricBalance[]     @relation("FabricBalanceSourcePhase")
  fabricBalancesTarget FabricBalance[]     @relation("FabricBalanceTargetPhase")
}

model PhasePlanDraft {
  id        String   @id @default(cuid())
  phaseId   String
  userId    String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phaseId, userId])
  @@index([phaseId])
}

model Vendor {
  id                      String              @id @default(cuid())
  name                    String              @unique
  type                    VendorType
  contactInfo             String?
  address                 String?
  isStrikedThrough        Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  productsByFabricVendor  Product[]           @relation("ProductFabricVendor")
  productsByFabric2Vendor Product[]           @relation("ProductFabric2Vendor")
  fabricOrders            FabricOrder[]       @relation("FabricOrderVendor")
  expenses                Expense[]           @relation("ExpenseVendor")
  fabricMasters           FabricMaster[]      @relation("FabricMasterVendor")
  accessoryMasters        AccessoryMaster[]   @relation("AccessoryMasterVendor")
  accessoryPurchases      AccessoryPurchase[] @relation("AccessoryPurchaseVendor")
  accessoryPurchasesShipTo AccessoryPurchase[] @relation("AccessoryPurchaseShipTo")
  fabricBalances          FabricBalance[]     @relation("FabricBalanceVendor")
}

enum VendorType {
  FABRIC_SUPPLIER
  GARMENTING
  ACCESSORIES
  BRAND_TAG
  OTHER
  PACKAGING
  INLAY_PRINTING
  REFLECTORS
  OFFICE
}

model Product {
  id      String @id @default(cuid())
  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id])

  // Identity
  orderDate     String  @default("15 Nov 2025")
  styleNumber   String
  articleNumber String?
  skuCode       String?
  colourOrdered String
  isRepeat      Boolean @default(false)

  // Bundle1 Phase A: nullable FKs introduced alongside string columns.
  // Both are written by app code during dual-write phase. Strings drop in Phase C.
  // Note: colourOrderedId only resolves for single-colour products. Multi-colour
  // SKUs (slash-separated combos) are represented in the ProductColour join table.
  colourOrderedId  String?
  colourOrderedRef Colour? @relation("ProductColourOrdered", fields: [colourOrderedId], references: [id])

  colourLinks ProductColour[]

  // Classification
  type        String
  gender      Gender
  productName String?

  typeRefId String?
  typeRef   ProductType? @relation("ProductType", fields: [typeRefId], references: [id])

  // Status
  status          ProductStatus @default(PLANNED)
  statusChangedAt DateTime      @default(now())

  // Primary Fabric
  fabricVendorId             String
  fabricVendor               Vendor   @relation("ProductFabricVendor", fields: [fabricVendorId], references: [id])
  fabricName                 String
  fabricGsm                  Decimal? @db.Decimal(10, 2)
  fabricCostPerKg            Decimal? @db.Decimal(10, 2)
  assumedFabricGarmentsPerKg Decimal? @db.Decimal(10, 2)

  // Secondary Fabric
  fabric2Name                 String?
  fabric2CostPerKg            Decimal? @db.Decimal(10, 2)
  assumedFabric2GarmentsPerKg Decimal? @db.Decimal(10, 2)
  fabric2VendorId             String?
  fabric2Vendor               Vendor?  @relation("ProductFabric2Vendor", fields: [fabric2VendorId], references: [id])

  // Cutting report - actual garments per kg measured after cutting
  cuttingReportGarmentsPerKg  Decimal? @db.Decimal(10, 2)
  cuttingReportGarmentsPerKg2 Decimal? @db.Decimal(10, 2)

  // Quantities
  fabricOrderedQuantityKg  Decimal? @db.Decimal(10, 2)
  fabricShippedQuantityKg  Decimal? @db.Decimal(10, 2)
  fabric2OrderedQuantityKg Decimal? @db.Decimal(10, 2)
  fabric2ShippedQuantityKg Decimal? @db.Decimal(10, 2)
  garmentNumber            Int?

  // Actual Stitched Size Breakdown
  actualStitchedXS  Int @default(0)
  actualStitchedS   Int @default(0)
  actualStitchedM   Int @default(0)
  actualStitchedL   Int @default(0)
  actualStitchedXL  Int @default(0)
  actualStitchedXXL Int @default(0)

  // Actual Inward Size Breakdown
  actualInwardXS    Int @default(0)
  actualInwardS     Int @default(0)
  actualInwardM     Int @default(0)
  actualInwardL     Int @default(0)
  actualInwardXL    Int @default(0)
  actualInwardXXL   Int @default(0)
  actualInwardTotal Int @default(0)

  // Garmenting Costs
  stitchingCost   Decimal? @db.Decimal(10, 2)
  brandLogoCost   Decimal? @db.Decimal(10, 2)
  neckTwillCost   Decimal? @db.Decimal(10, 2)
  reflectorsCost  Decimal? @db.Decimal(10, 2)
  fusingCost      Decimal? @db.Decimal(10, 2)
  accessoriesCost Decimal? @db.Decimal(10, 2)
  brandTagCost    Decimal? @db.Decimal(10, 2)
  sizeTagCost     Decimal? @db.Decimal(10, 2)
  packagingCost   Decimal? @db.Decimal(10, 2)

  // Pricing
  outwardShippingCost Decimal? @db.Decimal(10, 2)
  proposedMrp         Decimal? @db.Decimal(10, 2)
  onlineMrp           Decimal? @db.Decimal(10, 2)

  // Garment location
  garmentingAt    String?
  garmentingAtId  String?
  garmentingAtRef GarmentingLocation? @relation("ProductGarmentingAt", fields: [garmentingAtId], references: [id])

  // Invoice
  invoiceNumber String?

  // Link to auto-created expense
  expenseId String?
  expense   Expense? @relation("ProductExpense", fields: [expenseId], references: [id])

  isStrikedThrough Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabricOrderLinks    ProductFabricOrder[]
  accessoryDispatches AccessoryDispatch[]  @relation("ProductAccessoryDispatch")

  @@index([phaseId])
  @@index([styleNumber])
  @@index([fabricVendorId])
  @@index([fabric2VendorId])
  @@index([isRepeat])
  @@index([invoiceNumber])
  @@index([colourOrderedId])
  @@index([typeRefId])
  @@index([garmentingAtId])
}

enum Gender {
  MENS
  WOMENS
  KIDS
}

enum ProductStatus {
  PLANNED
  FABRIC_ORDERED
  FABRIC_RECEIVED
  CUTTING_IN_PROGRESS
  CUTTING_COMPLETED
  CUTTING_REPORT_RECEIVED
  STITCHING_IN_PROGRESS
  STITCHING_COMPLETED
  TRIMS_ACCESSORIES_ATTACHED
  QC_IN_PROGRESS
  QC_APPROVED
  QC_FAILED
  PACKAGING_IN_PROGRESS
  PACKAGING_COMPLETED
  READY_FOR_DISPATCH
  DISPATCHED
  RECEIVED_AT_WAREHOUSE
  SHIPPED
  DELIVERED
}

model FabricOrder {
  id             String @id @default(cuid())
  phaseId        String
  phase          Phase  @relation(fields: [phaseId], references: [id])
  fabricVendorId String
  fabricVendor   Vendor @relation("FabricOrderVendor", fields: [fabricVendorId], references: [id])

  gender        Gender?
  invoiceNumber String?
  receivedAt    String?
  orderDate     DateTime?

  articleNumbers  String
  fabricName      String
  colour          String
  availableColour String?
  costPerUnit     Decimal? @db.Decimal(10, 2)

  colourId           String?
  colourRef          Colour? @relation("FabricOrderColour", fields: [colourId], references: [id])
  availableColourId  String?
  availableColourRef Colour? @relation("FabricOrderAvailableColour", fields: [availableColourId], references: [id])

  fabricOrderedQuantityKg Decimal? @db.Decimal(10, 2)
  fabricShippedQuantityKg Decimal? @db.Decimal(10, 2)

  isRepeat Boolean @default(false)

  orderStatus     FabricOrderStatus @default(DRAFT_ORDER)
  statusChangedAt DateTime          @default(now())
  // Not unique: multiple FabricOrder rows in one vendor batch share a single
  // PO number (one printed PO, multiple fabric line items).
  poNumber        String?
  piReceivedAt    DateTime?
  advancePaidAt   DateTime?
  garmentingAt    String?
  garmentingAtId  String?
  garmentingAtRef GarmentingLocation? @relation("FabricOrderGarmentingAt", fields: [garmentingAtId], references: [id])

  // Link to auto-created expense
  expenseId String?
  expense   Expense? @relation("FabricOrderExpense", fields: [expenseId], references: [id])

  isStrikedThrough Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productLinks ProductFabricOrder[]

  @@index([phaseId])
  @@index([fabricVendorId])
  @@index([invoiceNumber])
  @@index([poNumber])
  @@index([colourId])
  @@index([availableColourId])
  @@index([garmentingAtId])
}

model ProductFabricOrder {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  fabricOrderId String
  fabricOrder   FabricOrder @relation(fields: [fabricOrderId], references: [id], onDelete: Cascade)
  fabricSlot    Int // 1 = primary fabric, 2 = secondary fabric
  createdAt     DateTime    @default(now())

  @@unique([productId, fabricOrderId, fabricSlot])
  @@index([productId])
  @@index([fabricOrderId])
}

enum FabricOrderStatus {
  DRAFT_ORDER
  PO_SENT
  PI_RECEIVED
  ADVANCE_PAID
  PARTIALLY_SHIPPED
  DISPATCHED
  RECEIVED
  FULLY_SETTLED
}

model PoCounter {
  fiscalYear String   @id // e.g. "2026-27"
  lastNumber Int      @default(100) // next allocation = lastNumber + 1, so default 100 → first PO is 0101
  updatedAt  DateTime @updatedAt
}

model Expense {
  id       String  @id @default(cuid())
  phaseId  String
  phase    Phase   @relation(fields: [phaseId], references: [id])
  vendorId String?
  vendor   Vendor? @relation("ExpenseVendor", fields: [vendorId], references: [id])

  invoiceNumber String?
  specification ExpenseType
  sourceType    ExpenseSourceType @default(MANUAL)
  date          DateTime?
  description   String?
  quantity      String?
  amount        Decimal           @db.Decimal(12, 2)

  deliveredAt String?
  productNote String?
  note        String?

  garmentBifurcation String?
  totalGarments      Int?

  fabricStatus   FabricStatus?
  inwardDate     DateTime?
  expectedInward DateTime?
  actualInward   DateTime?

  isStrikedThrough Boolean @default(false)

  // Reverse relations for auto-created expenses
  fabricOrders FabricOrder[] @relation("FabricOrderExpense")
  products     Product[]     @relation("ProductExpense")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
  @@index([vendorId])
  @@index([specification])
  @@index([date])
  @@index([invoiceNumber])
}

enum ExpenseType {
  FABRIC_VENDOR
  GARMENTING
  BRAND_TAG
  ACCESSORIES
  SHIPPING
  PACKAGING
  OTHER
}

enum ExpenseSourceType {
  MANUAL
  FABRIC_ORDER
  PRODUCT_ORDER
}

enum FabricStatus {
  FULLY_CONSUMED
  TO_BE_CONSUMED
  FULLY_INWARDED
  PARTIALLY_INWARDED
}

// ─── LISTS / LOOKUP DATA ─────────────────────────────────────────

model ProductType {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       Product[]       @relation("ProductType")
  productMasters ProductMaster[] @relation("ProductMasterType")
}

model GarmentingLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products            Product[]           @relation("ProductGarmentingAt")
  productMasters      ProductMaster[]     @relation("ProductMasterGarmentingAt")
  fabricOrders        FabricOrder[]       @relation("FabricOrderGarmentingAt")
  accessoryDispatches AccessoryDispatch[] @relation("AccessoryDispatchGarmenter")
  fabricBalances      FabricBalance[]     @relation("FabricBalanceGarmentingLocation")
}

model SizeDistribution {
  id         String   @id @default(cuid())
  size       String   @unique
  percentage Float
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── MASTER DATA ──────────────────────────────────────────────────

model FabricMaster {
  id                    String   @id @default(cuid())
  fabricName            String   @unique
  vendorId              String
  vendor                Vendor   @relation("FabricMasterVendor", fields: [vendorId], references: [id])
  genders               String[]
  articleNumbers        String[]
  deletedArticleNumbers String[] @default([])
  coloursAvailable      String[]
  mrp                   Decimal? @db.Decimal(10, 2)
  hsnCode               String?
  comments              String?
  isStrikedThrough      Boolean  @default(false)
  manuallyCleanedAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fabricBalances       FabricBalance[]
  coloursAvailableLink FabricMasterColour[]

  @@index([vendorId])
}

model FabricBalance {
  id             String       @id @default(cuid())
  fabricMasterId String
  fabricMaster   FabricMaster @relation(fields: [fabricMasterId], references: [id])
  vendorId       String
  vendor         Vendor       @relation("FabricBalanceVendor", fields: [vendorId], references: [id])
  colour         String
  colourId       String?
  colourRef      Colour?      @relation("FabricBalanceColour", fields: [colourId], references: [id])
  remainingKg    Decimal      @db.Decimal(12, 2)
  costPerKg      Decimal      @db.Decimal(10, 2)
  // costAttributed = remainingKg * costPerKg, computed at read time

  sourcePhaseId String?
  sourcePhase   Phase?  @relation("FabricBalanceSourcePhase", fields: [sourcePhaseId], references: [id])
  targetPhaseId String?
  targetPhase   Phase?  @relation("FabricBalanceTargetPhase", fields: [targetPhaseId], references: [id])

  notes                 String?
  updateDate            DateTime?
  garmentingLocation    String?
  garmentingLocationId  String?
  garmentingLocationRef GarmentingLocation? @relation("FabricBalanceGarmentingLocation", fields: [garmentingLocationId], references: [id])
  isStrikedThrough      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([fabricMasterId])
  @@index([vendorId])
  @@index([sourcePhaseId])
  @@index([targetPhaseId])
  @@index([colourId])
  @@index([garmentingLocationId])
}

model Colour {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabricMasterAvailable  FabricMasterColour[]
  productMasterAvailable ProductMasterColour[]
  productLinks           ProductColour[]
  fabricOrderColour      FabricOrder[]        @relation("FabricOrderColour")
  fabricOrderAvailable   FabricOrder[]        @relation("FabricOrderAvailableColour")
  fabricBalances         FabricBalance[]      @relation("FabricBalanceColour")
  products               Product[]            @relation("ProductColourOrdered")
  accessoryMasters       AccessoryMaster[]    @relation("AccessoryMasterColour")
}

model ProductColour {
  productId String
  colourId  String
  slot      Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  colour    Colour  @relation(fields: [colourId], references: [id])

  @@id([productId, colourId, slot])
  @@index([productId])
  @@index([colourId])
}

model FabricMasterColour {
  fabricMasterId String
  colourId       String
  fabricMaster   FabricMaster @relation(fields: [fabricMasterId], references: [id], onDelete: Cascade)
  colour         Colour       @relation(fields: [colourId], references: [id])

  @@id([fabricMasterId, colourId])
  @@index([colourId])
}

model ProductMasterColour {
  productMasterId String
  colourId        String
  slot            Int           // 1, 2, 3, 4 = which coloursNAvailable list the entry came from
  productMaster   ProductMaster @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  colour          Colour        @relation(fields: [colourId], references: [id])

  @@id([productMasterId, colourId, slot])
  @@index([colourId])
  @@index([productMasterId])
}

model PhaseCost {
  id         String @id @default(cuid())
  phaseId    String
  entityType String // "FABRIC_MASTER" or "PRODUCT_MASTER"
  entityId   String

  fabricCostPerKg  Decimal? @db.Decimal(10, 2)
  fabric2CostPerKg Decimal? @db.Decimal(10, 2)
  stitchingCost    Decimal? @db.Decimal(10, 2)
  brandLogoCost    Decimal? @db.Decimal(10, 2)
  neckTwillCost    Decimal? @db.Decimal(10, 2)
  reflectorsCost   Decimal? @db.Decimal(10, 2)
  fusingCost       Decimal? @db.Decimal(10, 2)
  accessoriesCost  Decimal? @db.Decimal(10, 2)
  brandTagCost     Decimal? @db.Decimal(10, 2)
  sizeTagCost      Decimal? @db.Decimal(10, 2)
  packagingCost    Decimal? @db.Decimal(10, 2)
  inwardShipping   Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phaseId, entityType, entityId])
  @@index([entityType, entityId])
}

model AlertRule {
  id                    String   @id // matches the rule id in src/lib/alert-rules-catalog.ts
  enabled               Boolean  @default(true)
  thresholdDays         Int?
  criticalThresholdDays Int? // only used by phase-deadline rule
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  action     String // CREATE, UPDATE, DELETE, ARCHIVE, MERGE
  entityType String // e.g. "FabricMaster", "ProductMaster", "FabricOrder"
  entityId   String
  changes    String? // JSON string of {field: {old, new}} diffs
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model ProductMaster {
  id                          String   @id @default(cuid())
  skuCode                     String   @unique
  styleNumber                 String
  articleNumber               String?
  fabricName                  String
  fabric2Name                 String?
  fabric3Name                 String?
  fabric4Name                 String?
  type                        String
  typeRefId                   String?
  typeRef                     ProductType? @relation("ProductMasterType", fields: [typeRefId], references: [id])
  gender                      Gender
  productName                 String?
  coloursAvailable            String[]
  colours2Available           String[]
  colours3Available           String[]
  colours4Available           String[]
  garmentsPerKg               Decimal? @db.Decimal(10, 2)
  garmentsPerKg2              Decimal? @db.Decimal(10, 2)
  garmentsPerKg3              Decimal? @db.Decimal(10, 2)
  garmentsPerKg4              Decimal? @db.Decimal(10, 2)
  cuttingReportGarmentsPerKg  Decimal? @db.Decimal(10, 2)
  cuttingReportGarmentsPerKg2 Decimal? @db.Decimal(10, 2)
  cuttingReportGarmentsPerKg3 Decimal? @db.Decimal(10, 2)
  cuttingReportGarmentsPerKg4 Decimal? @db.Decimal(10, 2)
  stitchingCost               Decimal? @db.Decimal(10, 2)
  brandLogoCost               Decimal? @db.Decimal(10, 2)
  neckTwillCost               Decimal? @db.Decimal(10, 2)
  reflectorsCost              Decimal? @db.Decimal(10, 2)
  fusingCost                  Decimal? @db.Decimal(10, 2)
  accessoriesCost             Decimal? @db.Decimal(10, 2)
  brandTagCost                Decimal? @db.Decimal(10, 2)
  sizeTagCost                 Decimal? @db.Decimal(10, 2)
  packagingCost               Decimal? @db.Decimal(10, 2)
  fabricCostPerKg             Decimal? @db.Decimal(10, 2)
  fabric2CostPerKg            Decimal? @db.Decimal(10, 2)
  fabric3CostPerKg            Decimal? @db.Decimal(10, 2)
  fabric4CostPerKg            Decimal? @db.Decimal(10, 2)
  inwardShipping              Decimal? @db.Decimal(10, 2)
  proposedMrp                 Decimal? @db.Decimal(10, 2)
  onlineMrp                   Decimal? @db.Decimal(10, 2)
  garmentingAt                String?
  garmentingAtId              String?
  garmentingAtRef             GarmentingLocation? @relation("ProductMasterGarmentingAt", fields: [garmentingAtId], references: [id])
  isStrikedThrough            Boolean  @default(false)
  manuallyCleanedAt           DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  accessoryLinks       ProductMasterAccessory[]
  coloursAvailableLink ProductMasterColour[]

  @@index([skuCode])
  @@index([styleNumber])
  @@index([typeRefId])
  @@index([garmentingAtId])
}

// ─── ACCESSORIES ─────────────────────────────────────────────────

enum AccessoryUnit {
  PIECES
  METERS
  KG
  GRAMS
  ROLLS
  PACKS
}

model AccessoryMaster {
  id                 String        @id @default(cuid())
  // displayName is the canonical human-facing string stored once and reused
  // everywhere (grid, BOM, dispatch note, purchase line). Always populated.
  displayName        String
  category           String
  // Per-category structured variant fields. The shape is defined by
  // src/lib/accessory-categories.ts and validated client-side.
  attributes         Json          @default("{}")
  // Tiered pricing as a JSON array of {minQty, rate}. Empty array means
  // defaultCostPerUnit is used instead.
  priceTiers         Json          @default("[]")
  unit               AccessoryUnit
  vendorId           String?
  vendor             Vendor?       @relation("AccessoryMasterVendor", fields: [vendorId], references: [id])
  defaultCostPerUnit Decimal?      @db.Decimal(10, 2)
  hsnCode            String?
  comments           String?
  imageUrl           String?
  isStrikedThrough   Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // ── Legacy columns, kept nullable for back-compat with existing consumers.
  // Old consumers still read these; new writes only go through displayName
  // and attributes. Can be dropped after the UI migration settles.
  baseName String?
  colour   String?
  size     String?

  colourId  String?
  colourRef Colour?  @relation("AccessoryMasterColour", fields: [colourId], references: [id])

  purchases    AccessoryPurchase[]
  dispatches   AccessoryDispatch[]
  productLinks ProductMasterAccessory[]

  @@index([category])
  @@index([vendorId])
  @@index([displayName])
  @@index([colourId])
}

model AccessoryPurchase {
  id          String          @id @default(cuid())
  phaseId     String
  phase       Phase           @relation(fields: [phaseId], references: [id])
  accessoryId String
  accessory   AccessoryMaster @relation(fields: [accessoryId], references: [id])
  vendorId    String?
  vendor      Vendor?         @relation("AccessoryPurchaseVendor", fields: [vendorId], references: [id])

  quantity      Decimal   @db.Decimal(12, 2)
  costPerUnit   Decimal?  @db.Decimal(10, 2)
  invoiceNumber String?
  purchaseDate  DateTime?
  comments      String?
  poNumber      String?

  status          AccessoryPurchaseStatus @default(DRAFT_ORDER)
  statusChangedAt DateTime                @default(now())

  shipToVendorId String?
  shipToVendor   Vendor? @relation("AccessoryPurchaseShipTo", fields: [shipToVendorId], references: [id])

  isStrikedThrough Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([phaseId])
  @@index([accessoryId])
  @@index([vendorId])
  @@index([poNumber])
  @@index([shipToVendorId])
}

enum AccessoryPurchaseStatus {
  DRAFT_ORDER
  PO_SENT
  PI_RECEIVED
  ADVANCE_PAID
  PARTIALLY_SHIPPED
  DISPATCHED
  RECEIVED
  FULLY_SETTLED
  CANCELLED
}

model AccessoryDispatch {
  id          String          @id @default(cuid())
  phaseId     String
  phase       Phase           @relation(fields: [phaseId], references: [id])
  accessoryId String
  accessory   AccessoryMaster @relation(fields: [accessoryId], references: [id])

  quantity Decimal @db.Decimal(12, 2)

  destinationGarmenter    String?
  destinationGarmenterId  String?
  destinationGarmenterRef GarmentingLocation? @relation("AccessoryDispatchGarmenter", fields: [destinationGarmenterId], references: [id])

  productId String?
  product   Product? @relation("ProductAccessoryDispatch", fields: [productId], references: [id])

  dispatchDate DateTime?
  comments     String?

  status          AccessoryDispatchStatus @default(DRAFT)
  statusChangedAt DateTime                @default(now())
  dnNumber        String?

  isStrikedThrough Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([phaseId])
  @@index([accessoryId])
  @@index([productId])
  @@index([dnNumber])
  @@index([destinationGarmenterId])
}

enum AccessoryDispatchStatus {
  DRAFT
  DISPATCHED
  RECEIVED
  CANCELLED
}

model ProductMasterAccessory {
  id              String          @id @default(cuid())
  productMasterId String
  productMaster   ProductMaster   @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  accessoryId     String
  accessory       AccessoryMaster @relation(fields: [accessoryId], references: [id])

  quantityPerPiece Decimal @db.Decimal(10, 4)
  notes            String?

  createdAt DateTime @default(now())

  @@unique([productMasterId, accessoryId])
  @@index([productMasterId])
  @@index([accessoryId])
}
