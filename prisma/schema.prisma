generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── CORE DOMAIN ─────────────────────────────────────────────────

model Phase {
  id           String        @id @default(cuid())
  name         String
  number       Int           @unique
  startDate    DateTime?
  endDate      DateTime?
  isCurrent        Boolean       @default(false)
  isStrikedThrough Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  products         Product[]
  fabricOrders     FabricOrder[]
  expenses         Expense[]
}

model Vendor {
  id               String        @id @default(cuid())
  name             String        @unique
  type             VendorType
  contactInfo      String?
  isStrikedThrough Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  productsByFabricVendor   Product[]      @relation("ProductFabricVendor")
  productsByFabric2Vendor  Product[]      @relation("ProductFabric2Vendor")
  fabricOrders             FabricOrder[]  @relation("FabricOrderVendor")
  expenses                 Expense[]      @relation("ExpenseVendor")
  fabricMasters            FabricMaster[] @relation("FabricMasterVendor")
}

enum VendorType {
  FABRIC_SUPPLIER
  GARMENTING
  ACCESSORIES
  BRAND_TAG
  OTHER
}

model Product {
  id      String @id @default(cuid())
  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id])

  // Identity
  orderDate     String  @default("15 Nov 2025")
  styleNumber   String
  articleNumber  String?
  skuCode        String?
  colourOrdered  String
  isRepeat       Boolean @default(false)

  // Classification
  type          String
  gender        Gender
  productName   String?

  // Status
  status        ProductStatus @default(PROCESSING)

  // Primary Fabric
  fabricVendorId             String
  fabricVendor               Vendor @relation("ProductFabricVendor", fields: [fabricVendorId], references: [id])
  fabricName                 String
  fabricGsm                  Decimal? @db.Decimal(10, 2)
  fabricCostPerKg            Decimal? @db.Decimal(10, 2)
  assumedFabricGarmentsPerKg Decimal? @db.Decimal(10, 2)

  // Secondary Fabric
  fabric2Name                    String?
  fabric2CostPerKg               Decimal? @db.Decimal(10, 2)
  assumedFabric2GarmentsPerKg    Decimal? @db.Decimal(10, 2)
  fabric2VendorId                String?
  fabric2Vendor                  Vendor?  @relation("ProductFabric2Vendor", fields: [fabric2VendorId], references: [id])

  // Quantities
  fabricOrderedQuantityKg   Decimal? @db.Decimal(10, 2)
  fabricShippedQuantityKg   Decimal? @db.Decimal(10, 2)
  fabric2OrderedQuantityKg  Decimal? @db.Decimal(10, 2)
  fabric2ShippedQuantityKg  Decimal? @db.Decimal(10, 2)
  garmentNumber             Int?

  // Actual Stitched Size Breakdown
  actualStitchedXS  Int @default(0)
  actualStitchedS   Int @default(0)
  actualStitchedM   Int @default(0)
  actualStitchedL   Int @default(0)
  actualStitchedXL  Int @default(0)
  actualStitchedXXL Int @default(0)

  // Actual Inward Size Breakdown
  actualInwardXS    Int @default(0)
  actualInwardS     Int @default(0)
  actualInwardM     Int @default(0)
  actualInwardL     Int @default(0)
  actualInwardXL    Int @default(0)
  actualInwardXXL   Int @default(0)
  actualInwardTotal Int @default(0)

  // Garmenting Costs
  stitchingCost   Decimal? @db.Decimal(10, 2)
  brandLogoCost   Decimal? @db.Decimal(10, 2)
  neckTwillCost   Decimal? @db.Decimal(10, 2)
  reflectorsCost  Decimal? @db.Decimal(10, 2)
  fusingCost      Decimal? @db.Decimal(10, 2)
  accessoriesCost Decimal? @db.Decimal(10, 2)
  brandTagCost    Decimal? @db.Decimal(10, 2)
  sizeTagCost     Decimal? @db.Decimal(10, 2)
  packagingCost   Decimal? @db.Decimal(10, 2)

  // Pricing
  outwardShippingCost Decimal? @db.Decimal(10, 2)
  proposedMrp         Decimal? @db.Decimal(10, 2)
  onlineMrp           Decimal? @db.Decimal(10, 2)

  // Garment location
  garmentingAt String?

  // Invoice
  invoiceNumber String?

  // Link to auto-created expense
  expenseId String?
  expense   Expense? @relation("ProductExpense", fields: [expenseId], references: [id])

  isStrikedThrough Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
  @@index([styleNumber])
  @@index([fabricVendorId])
  @@index([fabric2VendorId])
  @@index([isRepeat])
  @@index([invoiceNumber])
}

enum Gender {
  MENS
  WOMENS
  KIDS
}

enum ProductStatus {
  PROCESSING
  SAMPLE_WITH_ST
  SAMPLE_READY
  READY_AT_GARSEM
  READY_AT_MUMTAZ
  RECEIVED_AT_WAREHOUSE
  SHIPPED
}

model FabricOrder {
  id             String @id @default(cuid())
  phaseId        String
  phase          Phase  @relation(fields: [phaseId], references: [id])
  fabricVendorId String
  fabricVendor   Vendor @relation("FabricOrderVendor", fields: [fabricVendorId], references: [id])

  gender          Gender?
  invoiceNumber   String?
  receivedAt      String?
  orderDate       DateTime?

  styleNumbers    String
  fabricName      String
  colour          String
  availableColour String?
  costPerUnit     Decimal? @db.Decimal(10, 2)

  fabricOrderedQuantityKg Decimal? @db.Decimal(10, 2)
  fabricShippedQuantityKg Decimal? @db.Decimal(10, 2)

  isRepeat Boolean @default(false)

  orderStatus      FabricOrderStatus @default(DRAFT_ORDER)
  garmentingAt     String?

  // Link to auto-created expense
  expenseId String?
  expense   Expense? @relation("FabricOrderExpense", fields: [expenseId], references: [id])

  isStrikedThrough Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
  @@index([fabricVendorId])
  @@index([invoiceNumber])
}

enum FabricOrderStatus {
  DRAFT_ORDER
  ORDERED
  PARTIALLY_SHIPPED
  SHIPPED
  RECEIVED
}

model Expense {
  id       String  @id @default(cuid())
  phaseId  String
  phase    Phase   @relation(fields: [phaseId], references: [id])
  vendorId String?
  vendor   Vendor? @relation("ExpenseVendor", fields: [vendorId], references: [id])

  invoiceNumber String?
  specification ExpenseType
  sourceType    ExpenseSourceType @default(MANUAL)
  date          DateTime?
  description   String?
  quantity      String?
  amount        Decimal @db.Decimal(12, 2)

  deliveredAt String?
  productNote String?
  note        String?

  garmentBifurcation String?
  totalGarments      Int?

  fabricStatus   FabricStatus?
  inwardDate     DateTime?
  expectedInward DateTime?
  actualInward   DateTime?

  isStrikedThrough Boolean @default(false)

  // Reverse relations for auto-created expenses
  fabricOrders FabricOrder[] @relation("FabricOrderExpense")
  products     Product[]     @relation("ProductExpense")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
  @@index([vendorId])
  @@index([specification])
  @@index([date])
  @@index([invoiceNumber])
}

enum ExpenseType {
  FABRIC_VENDOR
  GARMENTING
  BRAND_TAG
  ACCESSORIES
  SHIPPING
  PACKAGING
  OTHER
}

enum ExpenseSourceType {
  MANUAL
  FABRIC_ORDER
  PRODUCT_ORDER
}

enum FabricStatus {
  FULLY_CONSUMED
  TO_BE_CONSUMED
  FULLY_INWARDED
  PARTIALLY_INWARDED
}

// ─── LISTS / LOOKUP DATA ─────────────────────────────────────────

model ProductType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarmentingLocation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SizeDistribution {
  id         String   @id @default(cuid())
  size       String   @unique
  percentage Float
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── MASTER DATA ──────────────────────────────────────────────────

model FabricMaster {
  id               String   @id @default(cuid())
  fabricName       String   @unique
  vendorId         String
  vendor           Vendor   @relation("FabricMasterVendor", fields: [vendorId], references: [id])
  genders          String[]
  styleNumbers     String[]
  coloursAvailable String[]
  mrp              Decimal? @db.Decimal(10, 2)
  isStrikedThrough Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([vendorId])
}

model ProductMaster {
  id                  String   @id @default(cuid())
  skuCode             String   @unique
  styleNumber         String
  articleNumber       String?
  fabricName          String
  fabric2Name         String?
  type                String
  gender              Gender
  productName         String?
  coloursAvailable    String[]
  colours2Available   String[]
  garmentsPerKg       Decimal? @db.Decimal(10, 2)
  garmentsPerKg2      Decimal? @db.Decimal(10, 2)
  stitchingCost       Decimal? @db.Decimal(10, 2)
  brandLogoCost       Decimal? @db.Decimal(10, 2)
  neckTwillCost       Decimal? @db.Decimal(10, 2)
  reflectorsCost      Decimal? @db.Decimal(10, 2)
  fusingCost          Decimal? @db.Decimal(10, 2)
  accessoriesCost     Decimal? @db.Decimal(10, 2)
  brandTagCost        Decimal? @db.Decimal(10, 2)
  sizeTagCost         Decimal? @db.Decimal(10, 2)
  packagingCost       Decimal? @db.Decimal(10, 2)
  fabricCostPerKg     Decimal? @db.Decimal(10, 2)
  fabric2CostPerKg    Decimal? @db.Decimal(10, 2)
  inwardShipping      Decimal? @db.Decimal(10, 2)
  proposedMrp         Decimal? @db.Decimal(10, 2)
  onlineMrp           Decimal? @db.Decimal(10, 2)
  isStrikedThrough    Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([skuCode])
  @@index([styleNumber])
}
